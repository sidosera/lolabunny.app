# Lolabunny signing / notarization secrets
# Copy to .env and fill in. .env is gitignored.
# Push to GitHub Actions:  gh secret set -f .env --repo sidosera/lolabunny.app

# Exact codesign identity name (security find-identity -v -p codesigning)
CODESIGN_IDENTITY=Apple Development: you@example.com (XXXXXXXXXX)

# Base64-encoded PKCS12 (.p12) of the signing identity
MACOS_CERTIFICATE=

# Password used when exporting the .p12
MACOS_CERTIFICATE_PWD=

# Apple team ID (OU on the certificate)
APPLE_TEAM_ID=

# Optional — notarization (app-specific password from appleid.apple.com)
APPLE_ID=
APPLE_ID_PWD=
