{% extends "base.j2" %}

{% block title %}lolabunny{% endblock %}
{% block heading %}lolabunny{% endblock %}
{% block subtitle %}{{ commands | length }} commands{% endblock %}

{% block head %}
.search { position: relative; margin-bottom: 24px; }
.search input {
  width: 100%;
  height: 28px;
  padding: 0 28px 0 32px;
  border: 1px solid rgba(0,0,0,0.08);
  border-radius: 100px;
  background: #fff;
  font-size: 13px;
  font-weight: 500;
  color: rgba(25,25,25,1);
  caret-color: rgba(0,135,255,1);
  outline: none;
  font-family: inherit;
  transition: border-color .2s, box-shadow .2s;
}
.search input:focus {
  border-color: rgba(0,122,255,0.15);
  box-shadow: 0 0 0 3.5px rgba(0,122,255,0.25);
}
.search input::placeholder { color: rgba(114,114,114,1); }
@media (prefers-color-scheme: dark) {
  .search input {
    background: rgba(255,255,255,0.1);
    border-color: transparent;
    color: var(--label-primary);
  }
  .search input:focus {
    background: rgba(217,217,217,1);
    border-color: rgba(0,135,255,0.15);
    box-shadow: 0 0 0 3.5px rgba(0,135,255,0.25);
    color: rgba(25,25,25,1);
    caret-color: rgba(0,135,255,1);
  }
  .search input::placeholder { color: rgba(114,114,114,1); }
}
.search-icon {
  position: absolute;
  left: 8px;
  top: 0;
  width: 21px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.search-icon svg { color: rgba(114,114,114,1); }
.search-clear {
  position: absolute;
  right: 6px;
  top: 0;
  width: 16px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  pointer-events: none;
  transition: opacity .15s;
}
.search-clear.visible { opacity: 1; pointer-events: auto; }
.search-clear svg { color: rgba(114,114,114,1); }
.search-clear:hover svg { color: rgba(25,25,25,1); }
.search-clear:active svg { color: rgba(25,25,25,1); }
@media (prefers-color-scheme: dark) {
  .search-clear svg { color: rgba(152,152,157,1); }
  .search-clear:hover svg { color: rgba(244,244,244,1); }
}
ul { list-style: none; }
li {
  border-bottom: 1px solid var(--separator);
  transition: background .15s;
}
li:last-child { border-bottom: none; }
li:hover { background: var(--fill-quaternary); }
li.hidden { display: none; }
.row { display: flex; align-items: baseline; padding: 11px 16px; gap: 14px; }
.cmd {
  font-family: var(--font-mono);
  font-size: 13px;
  font-weight: 600;
  color: var(--accent);
  white-space: nowrap;
  min-width: 64px;
  flex-shrink: 0;
}
.desc {
  font-size: 14px;
  color: var(--label-secondary);
  line-height: 1.4;
}
.alias {
  color: var(--label-tertiary);
  font-size: 12px;
  font-family: var(--font-mono);
  margin-left: 6px;
}
.empty {
  padding: 32px 16px;
  text-align: center;
  color: var(--label-tertiary);
  font-size: 14px;
  display: none;
}
{% endblock %}

{% block content %}
<div class="search">
<div class="search-icon">
<svg width="13" height="13" viewBox="0 0 13 13" fill="none"><circle cx="5" cy="5" r="4.25" stroke="currentColor" stroke-width="1.5"/><line x1="8" y1="8" x2="12" y2="12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
</div>
<input type="text" id="q" placeholder="Search" autocomplete="off" autofocus>
<div class="search-clear" id="clear">
<svg width="15" height="15" viewBox="0 0 15 15" fill="none"><circle cx="7.5" cy="7.5" r="7" fill="currentColor" opacity="0.25"/><path d="M5.25 5.25L9.75 9.75M9.75 5.25L5.25 9.75" stroke="currentColor" stroke-width="1.25" stroke-linecap="round"/></svg>
</div>
</div>
<div class="card">
<ul id="list">
{% for cmd in commands %}
<li data-cmd="{{ cmd.search }}">
<div class="row">
<span class="cmd">{{ cmd.binding }}</span>
<span class="desc">{{ cmd.description }}{% if cmd.aliases %}<span class="alias">{{ cmd.aliases }}</span>{% endif %}</span>
</div>
</li>
{% endfor %}
</ul>
<div class="empty" id="empty">No matching commands</div>
</div>
{% endblock %}

{% block scripts %}
<script>
const q=document.getElementById('q'),list=document.getElementById('list'),empty=document.getElementById('empty'),clr=document.getElementById('clear');
function filter(){const v=q.value.toLowerCase();let n=0;list.querySelectorAll('li').forEach(li=>{const m=li.dataset.cmd.includes(v);li.classList.toggle('hidden',!m);if(m)n++});empty.style.display=n?'none':'block';clr.classList.toggle('visible',q.value.length>0)}
q.addEventListener('input',filter);
clr.addEventListener('click',()=>{q.value='';q.focus();filter()});
</script>
{% endblock %}
